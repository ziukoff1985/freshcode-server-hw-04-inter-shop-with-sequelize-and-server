# Get all stores (only 10 items)
GET http://localhost:5000/api/stores

###

# Get all stores for IDs greater than half the total
GET http://localhost:5000/api/stores/half

###

# Get stores(array) by titles
POST http://localhost:5000/api/stores/by-titles HTTP/1.1
Content-Type: application/json

{
    "values": ["Retail Outlet", "Southern Port", "Main Warehouse"]
}

###

# Get store by id
GET http://localhost:5000/api/stores/2

###

# Create new store
POST http://localhost:5000/api/stores HTTP/1.1
Content-Type: application/json

{
    "title": "Shang Hai Factory",
    "description": "Some description about Shang Hai Factory"
}

###

# Update existing store by id
PUT http://localhost:5000/api/stores HTTP/1.1
Content-Type: application/json

{
    "id": 13,
    "title": "Odessa Factory",
    "description": "Some description about Odessa Factory"
}

###

# Delete store by id
DELETE http://localhost:5000/api/stores/12

###

# Delete brands(array) by titles
DELETE http://localhost:5000/api/stores/del-by-titles
Content-Type: application/json

{
  "values": ["Shang Hai Factory", "Odessa Factory"]
}