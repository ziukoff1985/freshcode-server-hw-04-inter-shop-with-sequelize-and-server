# Get all items (only 10 items)
GET http://localhost:5000/api/items

###

# Get all items for IDs greater than half the total
GET http://localhost:5000/api/items/half

###

# Get items(array) by brands
POST http://localhost:5000/api/items/by-brands HTTP/1.1
Content-Type: application/json

{
    "values": ["Xiaomi", "Samsung", "Dell"]
}

###

# Get item by id
GET http://localhost:5000/api/items/2

###

# Create new item
POST http://localhost:5000/api/items HTTP/1.1
Content-Type: application/json

{
    "categoryTitle": "Cameras",
    "typeTitle": "DSLR Camera",
    "brandTitle": "CNC",
    "modelTitle": "C920",
    "price": 100000.05,
    "storeTitle": "Retail Outlet",
    "amount": 5
}

###

# Update existing item by id
PUT http://localhost:5000/api/items HTTP/1.1
Content-Type: application/json

{
    "id": 58,
    "categoryTitle": "Gaming",
    "typeTitle": "Game Console",
    "brandTitle": "ENEXT",
    "modelTitle": "PlayStation 5",
    "price": 10000.05,
    "storeTitle": "Western Hub"
}

###

# Delete item by id
DELETE http://localhost:5000/api/items/58

###

# Delete items(array) by brands
DELETE http://localhost:5000/api/items/del-by-brands
Content-Type: application/json

{
  "values": ["ENEXT", "CNC"]
}
