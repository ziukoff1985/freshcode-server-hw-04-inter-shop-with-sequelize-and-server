# Get all types (only 10 items)
GET http://localhost:5000/api/types

###

# Get all types for IDs greater than half the total
GET http://localhost:5000/api/types/half

###

# Get types(array) by titles
POST http://localhost:5000/api/types/by-titles HTTP/1.1
Content-Type: application/json

{
    "values": ["OLED TV", "Treadmill", "Wi-Fi Router"]
}

###

# Get type by id
GET http://localhost:5000/api/types/2

###

# Create new type
POST http://localhost:5000/api/types HTTP/1.1
Content-Type: application/json

{
    "title": "Kitchen Appliances",
    "description": "Some description about Kitchen Appliances"
}

###

# Update existing type by id
PUT http://localhost:5000/api/types HTTP/1.1
Content-Type: application/json

{
    "id": 18,
    "title": "Bathroom Appliances",
    "description": "Some description about Bathroom Appliances"
}

###

# Delete type by id
DELETE http://localhost:5000/api/types/17

###

# Delete brands(array) by titles
DELETE http://localhost:5000/api/types/del-by-titles
Content-Type: application/json

{
  "values": ["Kitchen Appliances", "Bathroom Appliances"]
}