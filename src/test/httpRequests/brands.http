# Get all brands (only 10 items)
GET http://localhost:5000/api/brands

###

# Get all brands for IDs greater than half the total
GET http://localhost:5000/api/brands/half

###

# Get brands(array) by titles
POST http://localhost:5000/api/brands/by-titles HTTP/1.1
Content-Type: application/json

{
    "values": ["Xiaomi", "Samsung", "Dell"]
}

###

# Get brand by id
GET http://localhost:5000/api/brands/2

###

# Create new brand
POST http://localhost:5000/api/brands HTTP/1.1
Content-Type: application/json

{
    "title": "CNC",
    "description": "Some description about CNC"
}

###

# Update existing brand by id
PUT http://localhost:5000/api/brands HTTP/1.1
Content-Type: application/json

{
    "id": 43,
    "title": "Acer",
    "description": "Some description about Acer"
}

###

# Delete brand by id
DELETE http://localhost:5000/api/brands/42

###

# Delete brands(array) by titles
DELETE http://localhost:5000/api/brands/del-by-titles
Content-Type: application/json

{
  "values": ["Acer", "CNC"]
}