# Get all models (only 10 items)
GET http://localhost:5000/api/models

###

# Get all models for IDs greater than half the total
GET http://localhost:5000/api/models/half

###

# Get models(array) by titles
POST http://localhost:5000/api/models/by-titles HTTP/1.1
Content-Type: application/json

{
    "values": ["QLED 4K TV", "iPhone 15 Pro", "Hue Starter Kit"]
}

###

# Get model by id
GET http://localhost:5000/api/models/2

###

# Create new model
POST http://localhost:5000/api/models HTTP/1.1
Content-Type: application/json

{
    "title": "Mercy 4",
    "description": "Some description about Mercy 4",
    "brandTitle": "Bosch"
}

###

# Update existing model by id
PUT http://localhost:5000/api/models HTTP/1.1
Content-Type: application/json

{
    "id": 54,
    "title": "Jetpack 4",
    "description": "Some description about Jetpack 4",
    "brandTitle": "Sony"
}

###

# Delete model by id
DELETE http://localhost:5000/api/models/53

###

# Delete models(array) by titles
DELETE http://localhost:5000/api/models/del-by-titles
Content-Type: application/json

{
  "values": ["Jetpack 4", "Mercy 4"]
}