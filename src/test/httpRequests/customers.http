# Get all customers (only 10 items)
GET http://localhost:5000/api/customers?page=2

###

# Get all customers for IDs greater than half the total
GET http://localhost:5000/api/customers/half

###

# Get customers(array) by names
POST http://localhost:5000/api/customers/by-names HTTP/1.1
Content-Type: application/json

{
    "values": ["Michael Brown", "Karen White"]
}

###

# Get customer by id
GET http://localhost:5000/api/customers/2

###

# Create new customer
POST http://localhost:5000/api/customers HTTP/1.1
Content-Type: application/json

{
    "name": "Kate Windy",
    "email": "kate@test.com",
    "password": "123456"
}

###

# Update existing customer by id
PUT http://localhost:5000/api/customers HTTP/1.1
Content-Type: application/json

{
    "id": 19,
    "name": "Martin Johnson",
    "email": "martin@test.com",
    "password": "987654"
}

###

# Delete customer by id
DELETE http://localhost:5000/api/customers/18

###

# Delete customers(array) by names
DELETE http://localhost:5000/api/customers/del-by-names HTTP/1.1
Content-Type: application/json

{
    "values": ["Boris Ziukov", "Martin Johnson"]
}